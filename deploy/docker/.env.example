# GoAdmin Phase 1 local environment
# Copy this file to .env when using docker compose or shell-based local development.

# Application environment used by backend/core/config.
GOADMIN_ENV=dev
APP_ENV=dev

# Backend config directory used by the config loader and local scripts.
GOADMIN_CONFIG_DIR=backend/config

# HTTP server and local tooling.
GOADMIN_PORT=8080
GOADMIN_SERVER_HTTP_HOST=0.0.0.0
GOADMIN_SERVER_HTTP_PORT=8080
WEB_PORT=80
WEB_API_UPSTREAM=http://backend:8080
TZ=Asia/Shanghai

# Logger defaults for local development.
GOADMIN_LOGGER_LEVEL=debug
GOADMIN_LOGGER_FORMAT=console
GOADMIN_LOGGER_OUTPUT=stdout

# Database defaults for the Gorm repository layer.
GOADMIN_DATABASE_DRIVER=mysql
GOADMIN_DATABASE_DSN=goadmin:goadmin@tcp(mysql:3306)/goadmin?charset=utf8mb4&parseTime=True&loc=Local
GOADMIN_DATABASE_AUTO_MIGRATE=true
GOADMIN_DATABASE_LOG_SQL=true

# MySQL container bootstrap variables used by docker-compose.
MYSQL_PORT=3306
MYSQL_DATABASE=goadmin
MYSQL_USER=goadmin
MYSQL_PASSWORD=goadmin
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_ROOT_HOST=%
MYSQL_TIMEZONE=Asia/Shanghai
MYSQL_INITDB_SKIP_TZINFO=1

# PostgreSQL example:
# GOADMIN_DATABASE_DRIVER=postgres
# GOADMIN_DATABASE_DSN=host=postgres port=5432 user=goadmin password=goadmin dbname=goadmin sslmode=disable TimeZone=Asia/Shanghai

# PostgreSQL placeholder service.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=goadmin
POSTGRES_USER=goadmin
POSTGRES_PASSWORD=goadmin
POSTGRES_SSLMODE=disable
POSTGRES_TIMEZONE=Asia/Shanghai

# Redis placeholder service.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Common application placeholders for later phases.
CORS_ALLOW_ORIGINS=*
VITE_APP_TITLE=GoAdmin
VITE_API_BASE_URL=/api/v1
GOADMIN_AUTH_JWT_SECRET=please-change-me
GOADMIN_AUTH_JWT_ISSUER=GoAdmin
GOADMIN_AUTH_JWT_AUDIENCE=goadmin-api
GOADMIN_AUTH_JWT_ACCESS_TOKEN_TTL=2h
GOADMIN_AUTH_JWT_REFRESH_TOKEN_TTL=168h
GOADMIN_TENANT_ENABLED=true
GOADMIN_AUTH_CASBIN_ENABLED=true
GOADMIN_AUTH_CASBIN_MODEL_PATH=core/auth/casbin/model/rbac.conf
GOADMIN_AUTH_CASBIN_POLICY_PATH=core/auth/casbin/adapter/policy.csv
