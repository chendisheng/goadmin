{
  "name": "goadmin-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:vite": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "vue-tsc -b",
    "i18n:check-locales": "node scripts/i18n-validate-locales.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:i18n": "npm run i18n:check-locales && vitest run tests/i18n-loader.test.ts"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.7.9",
    "element-plus": "^2.8.8",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.0",
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^5.2.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
